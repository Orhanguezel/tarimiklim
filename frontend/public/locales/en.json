              "label": "Method support",
              "value": "3 types"
            },
            "two": {
              "label": "Crop templates",
              "value": "48"
            },
            "three": {
              "label": "Water savings",
              "value": "22%"
            },
            "four": {
              "label": "Integration",
              "value": "IoT sensors"
            }
          }

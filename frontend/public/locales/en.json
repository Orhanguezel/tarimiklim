              "label": "Accuracy (2024)",
              "value": "97.2%"
            }
          }
        },
        "forecast": {
          "index": "02 — Forecast",
          "titlePrefix": "Seven-day weather,",
          "titleEmphasis": "hourly detail.",
          "copy": "OpenWeatherMap primary, Open-Meteo fallback; district-scale resolution and parcel coordinates with Redis caching on a 30-minute TTL.",
          "features": {
            "one": {
              "label": "Data sources",
              "value": "2 + local"
            },
            "two": {
              "label": "Resolution",
              "value": "District · 9 km"
            },
            "three": {
              "label": "Refresh",
              "value": "Every 30 min"
            },
            "four": {
              "label": "Metrics",
              "value": "14"
            }
          }
        },
        "irrigation": {
          "index": "03 — Irrigation",
          "titlePrefix": "Irrigation plan,",
          "titleEmphasis": "with evapotranspiration.",
          "copy": "ETo calculation, rain forecast and soil type are combined into a parcel-specific schedule with dedicated formulas for drip, sprinkler and flood methods.",

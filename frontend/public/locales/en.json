    "pillars": {
      "label": "Core Modules",
      "title": {
        "line1": "Three services.",
        "line2": "One infrastructure."
      },
      "lead": "Each module is already shipped as an API; together they turn planting, irrigation and harvest planning into data-driven decisions.",
      "items": {
        "risk": {
          "index": "01 — Risk",
          "titlePrefix": "Frost risk,",
          "titleEmphasis": "four factors.",
          "copy": "A score blending temperature drop rate, humidity, wind and cloud cover. Different thresholds for orchards and open fields; SMS and Telegram alerts at ≤-2°C.",

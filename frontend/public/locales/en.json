    "api": {
      "label": "API & Widget",
      "title": {
        "prefix": "Fetch your first forecast",
        "emphasis": "in three lines."
      },
      "lead": "Use REST endpoints or a one-line iframe widget — the same infrastructure already powers Bereketfide and VistaSeed sidebars.",
      "code": {
        "filename": "terminal · curl",
        "copy": "Copy",
        "body": "# 7-day forecast + frost risk score\ncurl 'https://api.tarimiklim.com/v2/forecast' \\\n  -H 'Authorization: Bearer tk_live_...' \\\n  -d \"'{' \"lat\": 37.5731, \"lon\": 32.7734, \"days\": 7 '}'\"\n\n# -> response (trimmed)\n'{'\n  \"location\": \"Konya · Cumra\",\n  \"updated_at\": \"2026-04-17T14:32:18Z\",\n  \"frost_risk_24h\": 0.78,\n  \"frost_level\": \"critical\",\n  \"forecast\": [\n    '{' \"t\": \"06:00\", \"temp\": -2.1, \"hum\": 89 '}',\n    '{' \"t\": \"09:00\", \"temp\": 4.8, \"hum\": 72 '}'\n  ],\n  \"irrigation_advice\": \"skip_wednesday_night\"\n'}'",
        "copied": "Copied",
        "copyError": "Error"
      },
      "side": {
        "titlePrefix": "REST API,",
        "titleEmphasis": "JS SDK, iframe widget.",
        "copy": "Get an API key and make your first call in 60 seconds. Rate limit 10k req/min · p95 response 48ms."
      },
      "endpoints": {
        "forecast": {
          "method": "GET",
          "path": "/v2/forecast",
          "copy": "7-day hourly forecast"
        },
        "frostRisk": {
          "method": "GET",
          "path": "/v2/frost-risk",
          "copy": "24/48/72h frost score"
        },
        "irrigation": {
          "method": "GET",
          "path": "/v2/irrigation/plan",
          "copy": "Parcel-level irrigation schedule"
        },
        "alerts": {
          "method": "POST",
          "path": "/v2/alerts/subscribe",
          "copy": "SMS/TG subscription"
        },
        "stations": {
          "method": "GET",
          "path": "/v2/stations/nearby",
          "copy": "Nearest weather station"
        },
        "widget": {
          "method": "GET",
          "path": "/widget/embed.js",
          "copy": "Single-line iframe"
        }
      }
    },

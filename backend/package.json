{
  "name": "hava-durumu-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun x tsc -p tsconfig.json && bun x tsc-alias -p tsconfig.json",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:seed": "bun src/db/seed/index.ts",
    "db:seed:no-drop": "bun src/db/seed/index.ts --no-drop"
  },
  "dependencies": {
    "@agro/shared-backend": "workspace:*",
    "@agro/shared-types": "workspace:*",
    "@fastify/cookie": "^11",
    "@fastify/cors": "^11",
    "@fastify/jwt": "^10",
    "@fastify/multipart": "^9",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "argon2": "^0.41.0",
    "bullmq": "^5.73.0",
    "drizzle-orm": "^0.44.6",
    "fastify": "^5",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "2.0.0",
    "firebase-admin": "^13.0.0",
    "ioredis": "^5.10.1",
    "mysql2": "^3.15.3",
    "nodemailer": "^7.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ioredis": "^5.0.0",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.31.0",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.8.3"
  }
}

# Server
PORT=8088
NODE_ENV=development
HOST=127.0.0.1

# Database (MySQL)
# Local gelistirme: localhost (mysql2 cogu kurulumda app@localhost ile uyumlu)
# 127.0.0.1 kullanirsaniz MySQL'de ayri 'app'@'127.0.0.1' kullanicisi ve yetki gerekir
# Dogrudan MySQL: 3306 | Bu repodaki docker-compose db → host 3316
DB_HOST=localhost
DB_PORT=3306
# TCP yerine Unix soketi (onerilir: localhost + app@localhost ile uyum)
# Linux (Ubuntu): /var/run/mysqld/mysqld.sock | macOS Homebrew: /tmp/mysql.sock
# Bos birakilirsa mysql2 host+port (TCP) kullanir; 127.0.0.1 icin ayri MySQL kullanicisi gerekir
DB_SOCKET_PATH=
DB_USER=app
DB_PASSWORD=app
DB_NAME=hava_durumu

# Auth (ekosistem ortak)
JWT_SECRET=change-me-long-random-jwt-secret-min-32-chars
COOKIE_SECRET=change-me-long-random-cookie-secret
AUTH_ADMIN_EMAILS=admin@example.com,admin@hava-durumu.local

# Seed (db:seed) — yerel admin kullanicisi; uretimde farkli SEED_ADMIN_PASSWORD kullanin
SEED_ADMIN_EMAIL=admin@hava-durumu.local
SEED_ADMIN_PASSWORD=HavaDurumuDev2026!

# CORS
CORS_ORIGIN=http://localhost:3088,http://localhost:3048,http://127.0.0.1:3088,http://127.0.0.1:3048

# Storage (Cloudinary veya local)
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./uploads
LOCAL_STORAGE_BASE_URL=http://localhost:8088
CDN_PUBLIC_BASE=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=hava-durumu

# Hava Durumu API
WEATHER_API_PROVIDER=openweathermap
# Bos birakilirsa NODE_ENV=development iken ornek (mock) tahmin doner
OPENWEATHERMAP_API_KEY=
WEATHER_CACHE_TTL_SECONDS=1800

# MGM (Meteoroloji Genel Mudurlugu — alternatif/yedek)
MGM_API_URL=
MGM_API_KEY=

# Redis (cache)
# Dogrudan Redis: 6379 | docker-compose redis → host 6389
REDIS_URL=redis://127.0.0.1:6379

# Telegram (don uyarisi bildirimleri)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALERT_CHANNEL_ID=-100000000000

# SMTP (email uyarilari)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@agro.com.tr

# Sentry (monitoring)
SENTRY_DSN=

# Public URLs
PUBLIC_URL=http://localhost:8088
FRONTEND_URL=http://localhost:3088

# Google OAuth (shared auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
